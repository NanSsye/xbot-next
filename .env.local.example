# xbot local simple profile.
# Suitable for first run: SQLite + in-process memory queue + optional WeChat channel.

XBOT_LOAD_DOTENV=true

XBOT_STORAGE_TYPE=sqlite
XBOT_DATABASE_URL=sqlite+aiosqlite:///data/xbot.db
XBOT_ADMIN_DATABASE_URL=
XBOT_DATABASE_AUTO_BOOTSTRAP=true
XBOT_DATABASE_RUN_MIGRATIONS_ON_STARTUP=true

XBOT_CONVERSATION_STORE=sqlite
XBOT_QUEUE_TYPE=memory

XBOT_LLM_ENABLED=true
XBOT_LLM_BASE_URL=https://api.openai.com/v1
XBOT_LLM_MODEL=gpt-4.1-mini
XBOT_LLM_CONTEXT_WINDOW_TOKENS=128000
XBOT_LLM_TIMEOUT_SECONDS=60
XBOT_LLM_MAX_ATTEMPTS=3
XBOT_LLM_RETRY_BACKOFF_SECONDS=1.0
XBOT_LLM_API_KEY=change-me

# iLink is the easiest WeChat channel for local mode. It prints a QR code link on xbot run.
XBOT_WECHAT_ILINK_ENABLED=true
XBOT_WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
XBOT_WECHAT_ILINK_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
XBOT_WECHAT_ILINK_POLL_INTERVAL_SECONDS=1.0
XBOT_WECHAT_ILINK_CONNECT_TIMEOUT_SECONDS=45
XBOT_WECHAT_ILINK_MEDIA_ENABLED=true

# 869 is optional. Enable it when an 869 service is already running.
XBOT_WECHAT869_ENABLED=false
XBOT_WECHAT869_HOST=127.0.0.1
XBOT_WECHAT869_PORT=5253
XBOT_WECHAT869_WS_URL=ws://127.0.0.1:5253/ws/GetSyncMsg
XBOT_WECHAT869_TOKEN_KEY=
XBOT_WECHAT869_BOT_WXID=
XBOT_WECHAT869_BOT_NICKNAME=xbot
XBOT_WECHAT869_MEDIA_ENABLED=true

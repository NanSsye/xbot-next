# xbot 配置文件路径。
XBOT_CONFIG_FILE=configs/xbot.toml

# 是否自动读取项目根目录的 .env 文件。
# 测试或特殊部署场景可以设为 false，避免加载本地私有配置。
XBOT_LOAD_DOTENV=true

# 后端监听地址。默认 0.0.0.0 支持局域网设备访问。
# 手机访问时使用电脑局域网 IP，例如 http://192.168.6.34:8548
XBOT_SERVER_HOST=0.0.0.0
XBOT_SERVER_PORT=8548

# Docker 运行配置。
# 用户使用 Docker 时，复制本文件为 .env 后直接 docker compose up -d --build。
# compose 会把数据库和 Redis 地址覆盖为容器内服务名，因此下面的 XBOT_DATABASE_URL/XBOT_REDIS_URL
# 可以同时兼容非 Docker 部署说明和 Docker 默认部署。
INSTALL_PLAYWRIGHT=true
XBOT_DOCKER_INSTALL_DEPS_ON_START=true
XBOT_DOCKER_BUILD_UI_ON_START=true

# Web/API 控制台认证。
# 生产环境必须开启，并把 token 改成足够长的随机值。
# Windows 生成示例：[guid]::NewGuid().ToString("N") + [guid]::NewGuid().ToString("N")
XBOT_API_AUTH_ENABLED=false
XBOT_API_TOKEN=change-me-long-random-token
# 跨域访问前端时配置；同源部署可留空。多个来源用英文逗号分隔。
XBOT_API_CORS_ORIGINS=

# Agent 执行核心默认使用内嵌 Hermes。
# xbot 只保留通道、插件、API、任务记录和消息框架；Agent 记忆、压缩、工具循环、轨迹由 Hermes 负责。
# 旧版 XBOT_AGENT_TOOLSETS_*、XBOT_AGENT_CACHE_*、XBOT_AGENT_MEMORY_COMPACTION_*、XBOT_AGENT_WORKSPACE_* 已不再用于 Agent 执行。

# 存储模式：postgresql 或 sqlite。
# 简易版可用 sqlite+aiosqlite:///data/xbot.db；生产版建议 postgresql。
XBOT_STORAGE_TYPE=postgresql

# 应用运行时使用的数据库连接串。
# 这个账号用于正常读写业务表，不建议使用 postgres 超级用户。
XBOT_DATABASE_URL=postgresql+asyncpg://xbot:xbot@192.168.6.19:5433/xbot

# PostgreSQL 管理员连接串，仅用于首次自动初始化。
# 当目标 database 或应用 role 不存在时，框架会用它创建 database/role。
# 初始化完成后，应用仍使用上面的 XBOT_DATABASE_URL 运行。
# 请部署时改成真实管理员密码，不要提交真实密码到代码仓库。
XBOT_ADMIN_DATABASE_URL=postgresql://postgres:change-me@192.168.6.19:5433/postgres

# 是否在启动时自动检测并初始化数据库。
# true：启动时自动创建缺失的 database/role，并执行 Alembic migration。
# false：启动时只按现有数据库连接运行，不做自动创建。
XBOT_DATABASE_AUTO_BOOTSTRAP=true

# 是否在启动时自动执行 Alembic migration 到 head。
# 正常生产更新软件时建议保持 true，避免用户手动迁移数据库。
XBOT_DATABASE_RUN_MIGRATIONS_ON_STARTUP=true

# 会话存储随数据库模式选择：postgresql 或 sqlite。
XBOT_CONVERSATION_STORE=postgresql

# 队列模式：memory 或 redis。简易版可用 memory；生产版建议 redis。
XBOT_QUEUE_TYPE=redis

# Redis 连接串。
# 当前使用 /15，避免和同一 Redis 上的其他项目混用默认 /0。
XBOT_REDIS_URL=redis://192.168.6.41:6379/15

# Agent LLM provider 配置。Hermes 会复用这些模型参数。
# provider 支持 openai_compatible 和 anthropic。
# openai_compatible 使用 /chat/completions；anthropic 或 base_url 以 /anthropic 结尾时使用 Anthropic Messages 格式。
# 可以接 OpenAI、Anthropic、MiniMax、本地或第三方兼容服务。
XBOT_LLM_ENABLED=false
XBOT_LLM_PROVIDER=openai_compatible
XBOT_LLM_BASE_URL=https://api.openai.com/v1
XBOT_LLM_MODEL=gpt-4.1-mini
# 可选：模型上下文窗口大小。
XBOT_LLM_CONTEXT_WINDOW_TOKENS=128000
# 单次请求超时和瞬时失败重试；只重试网络错误、超时、429/5xx。
XBOT_LLM_TIMEOUT_SECONDS=60
XBOT_LLM_MAX_ATTEMPTS=3
XBOT_LLM_RETRY_BACKOFF_SECONDS=1.0

# LLM API Key。请部署时填写真实密钥，不要提交真实密钥到代码仓库。
XBOT_LLM_API_KEY=change-me

# 869 普通成员 Agent 工具策略。
# 普通成员可以用 Hermes 做代码/文件/搜索任务，但文件只能读写这些授权目录，且默认禁止访问 localhost/内网/同网段目标。
# 多个目录用英文逗号分隔；相对路径按项目根目录解析。
XBOT_AGENT_MEMBER_POLICY_ENABLED=true
XBOT_AGENT_MEMBER_WORKSPACE_ROOTS=workspace,.agent-workspace
XBOT_AGENT_MEMBER_ALLOW_TERMINAL=true
XBOT_AGENT_MEMBER_ALLOW_PUBLIC_WEB=true
XBOT_AGENT_MEMBER_BLOCK_PRIVATE_NETWORK=true

# 869 微信协议通道配置。
# 这里不负责登录，只复用已登录 869 服务的 token/admin key 来收发文本消息。
XBOT_WECHAT869_ENABLED=false
XBOT_WECHAT869_HOST=192.168.6.19
XBOT_WECHAT869_PORT=8848
XBOT_WECHAT869_WS_URL=ws://192.168.6.19:8848/ws/GetSyncMsg
XBOT_WECHAT869_ADMIN_KEY=change-me
XBOT_WECHAT869_TOKEN_KEY=
# 869 管理员 wxid，多个用英文逗号分隔。
# 管理员拥有 Hermes 完整工具权限。
XBOT_WECHAT869_ADMIN_WXIDS=
# 869 普通成员 wxid，多个用英文逗号分隔。留空时，非管理员默认按 XBOT_WECHAT869_DEFAULT_PROFILE 处理。
XBOT_WECHAT869_MEMBER_WXIDS=
# 非管理员且不在成员名单时的默认权限：member 或 guest。
# member：受限工具，可在授权目录内写代码；guest：只聊天，不调用工具。
XBOT_WECHAT869_DEFAULT_PROFILE=member
# 可选：群聊 @ 优先从 869 WS msg_source.atuserlist 自动识别；这里仅用于兜底和过滤自身消息。
XBOT_WECHAT869_BOT_WXID=
# 可选：仅当 869 消息缺少 atuserlist 时，用昵称文本匹配作为兜底。
XBOT_WECHAT869_BOT_NICKNAME=

# iLink 微信通道配置。
# 这是独立于 869 的第二个微信通道，可以单独开启，也可以和 869 同时开启。
XBOT_WECHAT_ILINK_ENABLED=false
XBOT_WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
XBOT_WECHAT_ILINK_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
XBOT_WECHAT_ILINK_POLL_INTERVAL_SECONDS=1.0
XBOT_WECHAT_ILINK_CONNECT_TIMEOUT_SECONDS=45
XBOT_WECHAT_ILINK_MEDIA_ENABLED=true
XBOT_WECHAT_ILINK_MEDIA_DIR=data/wechat_ilink/media
XBOT_WECHAT_ILINK_AUTO_DOWNLOAD_IMAGES=true
XBOT_WECHAT_ILINK_AUTO_DOWNLOAD_FILES=true
XBOT_WECHAT_ILINK_MAX_IMAGE_BYTES=20971520
XBOT_WECHAT_ILINK_MAX_FILE_BYTES=104857600

# Docker 本地构建运行配置。
# 使用方式：
#   copy .env.docker.example .env.docker
#   docker compose up -d --build

XBOT_CONFIG_FILE=/app/configs/xbot.toml
XBOT_LOAD_DOTENV=true

XBOT_SERVER_HOST=0.0.0.0
XBOT_SERVER_PORT=8548

# Web/API 控制台认证。正式对外访问建议开启并替换 token。
XBOT_API_AUTH_ENABLED=false
XBOT_API_TOKEN=change-me-long-random-token
XBOT_API_CORS_ORIGINS=

# Docker compose 内置 PostgreSQL/Redis，通常不需要改。
XBOT_STORAGE_TYPE=postgresql
XBOT_DATABASE_URL=postgresql+asyncpg://xbot:xbot@postgres:5432/xbot
XBOT_ADMIN_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres
XBOT_DATABASE_AUTO_BOOTSTRAP=true
XBOT_DATABASE_RUN_MIGRATIONS_ON_STARTUP=true
XBOT_CONVERSATION_STORE=postgresql
XBOT_QUEUE_TYPE=redis
XBOT_REDIS_URL=redis://redis:6379/15

# Docker 启动时会检查映射目录里的依赖和前端源码。
# 代码替换升级后，只需要重启 xbot 容器；依赖或前端变化会自动安装/构建。
XBOT_DOCKER_INSTALL_DEPS_ON_START=true
XBOT_DOCKER_BUILD_UI_ON_START=true

# LLM 默认关闭。需要 Agent 时填写真实配置。
XBOT_LLM_ENABLED=false
XBOT_LLM_PROVIDER=openai_compatible
XBOT_LLM_BASE_URL=https://api.openai.com/v1
XBOT_LLM_MODEL=gpt-4.1-mini
XBOT_LLM_CONTEXT_WINDOW_TOKENS=128000
XBOT_LLM_API_KEY=change-me
XBOT_LLM_TIMEOUT_SECONDS=60
XBOT_LLM_MAX_ATTEMPTS=3
XBOT_LLM_RETRY_BACKOFF_SECONDS=1.0

# Agent 权限。Docker 内默认只访问容器 /app/workspace 和项目目录。
XBOT_AGENT_MODE=developer
XBOT_AGENT_ADMIN_MODE_ALLOWED=false
XBOT_AGENT_ALLOW_SHELL=false
XBOT_AGENT_ALLOW_FILE_WRITE=true
XBOT_AGENT_MAX_TOOL_ITERATIONS=0
XBOT_AGENT_AUTO_DELEGATE_CHANNEL_TASKS=true
XBOT_AGENT_WORKSPACE_ROOT=/app/workspace
XBOT_AGENT_WORKSPACE_ROOTS=/app/workspace;/app
XBOT_AGENT_WORKSPACE_ALLOW_ALL_FILESYSTEM=false
XBOT_AGENT_WORKSPACE_ALLOW_OUTSIDE=false

# 869 通道。869 服务在宿主机或局域网时，把 host 改成实际 IP。
# Windows/Mac Docker Desktop 访问宿主机也可尝试 host.docker.internal。
XBOT_WECHAT869_ENABLED=false
XBOT_WECHAT869_HOST=host.docker.internal
XBOT_WECHAT869_PORT=8848
XBOT_WECHAT869_WS_URL=ws://host.docker.internal:8848/ws/GetSyncMsg
XBOT_WECHAT869_ADMIN_KEY=change-me
XBOT_WECHAT869_TOKEN_KEY=
XBOT_WECHAT869_BOT_WXID=
XBOT_WECHAT869_BOT_NICKNAME=

# iLink 通道。
XBOT_WECHAT_ILINK_ENABLED=false
XBOT_WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
XBOT_WECHAT_ILINK_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
XBOT_WECHAT_ILINK_POLL_INTERVAL_SECONDS=1.0
XBOT_WECHAT_ILINK_CONNECT_TIMEOUT_SECONDS=45

# OpenClaw 桥插件配置。启用插件后生效。
XBOT_OPENCLAW_BRIDGE_URL=http://host.docker.internal:1569
XBOT_OPENCLAW_SHARED_SECRET=
XBOT_OPENCLAW_AGENT_ID=main
XBOT_OPENCLAW_GROUP_AT_ONLY=true
XBOT_OPENCLAW_STORE_UNTRIGGERED_GROUP_MESSAGES=true

# 构建参数：不需要浏览器工具时可加速构建。
INSTALL_PLAYWRIGHT=true
